# Lightdash 连接配置（必填）
LIGHTDASH_URL=https://your-lightdash.example.com
LIGHTDASH_TOKEN=ldpat_your_token_here
LIGHTDASH_PROJECT_UUID=your-project-uuid

# MCP HTTP 服务配置
LIGHTDASH_MCP_HTTP_HOST=0.0.0.0
LIGHTDASH_MCP_HTTP_PORT=8082

# APIKEY 认证（必填）
LIGHTDASH_MCP_HTTP_APIKEY=change_me_to_a_secure_random_string

# 外部 API（可选）
CPVMATCH_APIKEY=
